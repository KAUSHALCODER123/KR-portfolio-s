---
import '../styles/global.css';
import { config } from '../config.js';

const { title, description } = Astro.props;
const pageTitle = title ?? `${config.doctor.name} — ${config.doctor.specialization}`;
const pageDesc =
  description ??
  `${config.doctor.name}, ${config.doctor.qualifications}. ${config.doctor.specialization} at ${config.clinic.name}. Book an appointment today.`;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Progressive enhancement: only hide reveal elements once JS is present. -->
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#1E3A5F" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <script>
      // Scroll-reveal: elements rise into view once, then stop being observed.
      const reveals = document.querySelectorAll('[data-reveal]');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (reduce || !('IntersectionObserver' in window)) {
        reveals.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
        );
        reveals.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>

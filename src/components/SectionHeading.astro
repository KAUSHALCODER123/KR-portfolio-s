---
const { eyebrow, title } = Astro.props;
---

<div data-reveal class="mx-auto mb-12 max-w-2xl text-center">
  {
    eyebrow && (
      <span class="text-sm font-700 uppercase tracking-[0.18em] text-gold-dark">
        {eyebrow}
      </span>
    )
  }
  <h2 class="mt-2 font-serif text-3xl font-700 text-navy sm:text-4xl">{title}</h2>
  <div class="mx-auto mt-4 h-1 w-16 rounded-full bg-gold"></div>
</div>

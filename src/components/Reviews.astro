---
import { config } from '../config.js';
import SectionHeading from './SectionHeading.astro';

const { reviews } = config;
---

<section id="reviews" class="bg-navy py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-5">
    <div data-reveal class="mx-auto mb-12 max-w-2xl text-center">
      <span class="text-sm font-700 uppercase tracking-[0.18em] text-gold">
        Testimonials
      </span>
      <h2 class="mt-2 font-serif text-3xl font-700 text-white sm:text-4xl">
        What Patients Say
      </h2>
      <div class="mx-auto mt-4 h-1 w-16 rounded-full bg-gold"></div>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {
        reviews.map((r, i) => (
          <figure
            data-reveal
            style={`--reveal-delay:${i * 90}ms`}
            class="flex flex-col rounded-2xl bg-white p-7 shadow-lg transition-transform duration-300 hover:-translate-y-1.5"
          >
            <div class="mb-4 flex gap-1" aria-label={`${r.rating} out of 5 stars`}>
              {Array.from({ length: 5 }).map((_, i) => (
                <svg
                  class={i < r.rating ? 'h-5 w-5 text-gold' : 'h-5 w-5 text-gray-200'}
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M12 2l2.9 6.1 6.6.9-4.8 4.7 1.2 6.6L12 17.8 6.1 20.3l1.2-6.6L2.5 9l6.6-.9z" />
                </svg>
              ))}
            </div>
            <blockquote class="grow text-sm leading-relaxed text-gray-600">
              “{r.text}”
            </blockquote>
            <figcaption class="mt-5 flex items-center gap-3 border-t border-gray-100 pt-4">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-navy font-600 text-gold">
                {r.name.charAt(0)}
              </span>
              <span class="font-600 text-navy">{r.name}</span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>

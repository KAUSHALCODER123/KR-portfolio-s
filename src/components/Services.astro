---
import { config } from '../config.js';
import SectionHeading from './SectionHeading.astro';

const { services } = config;

// SVG path sets keyed by config `icon`. Add more keys as needed.
const icons = {
  stethoscope:
    'M4 3v7a5 5 0 0 0 10 0V3M4 3H2m2 0h2m6 0h2m-2 0h-2M9 19a4 4 0 0 0 8 0v-2m0 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4z',
  child:
    'M12 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4zM6 21v-6a6 6 0 0 1 12 0v6M9 11h6',
  droplet: 'M12 2.5S5.5 9 5.5 14a6.5 6.5 0 0 0 13 0c0-5-6.5-11.5-6.5-11.5z',
  heart:
    'M12 21s-7.5-4.6-10-9.3C.4 8.4 2 4.5 5.5 4.5c2 0 3.4 1.2 4.5 2.7 1.1-1.5 2.5-2.7 4.5-2.7 3.5 0 5.1 3.9 3.5 7.2C19.5 16.4 12 21 12 21z',
  pulse: 'M3 12h4l2-7 4 14 2-7h6',
  leaf: 'M11 20A7 7 0 0 1 4 13c0-5 5-9 16-9 0 11-4 16-9 16zM4 21c4-7 8-9 13-10',
  shield: 'M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6l7-3zM9.5 12l1.8 1.8 3.2-3.6',
  thermometer:
    'M10 13.5V5a2 2 0 1 1 4 0v8.5a4 4 0 1 1-4 0zM12 9v6',
  wind: 'M9.6 4.6A2 2 0 1 1 11 8H2m10.6 11.4A2 2 0 1 0 14 16H2m15.7-8.3A2.5 2.5 0 1 1 19.5 12H2',
};
---

<section id="services" class="bg-cream py-20">
  <div class="mx-auto max-w-6xl px-5">
    <SectionHeading eyebrow="What We Offer" title="Services & Specialties" />

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((s) => (
          <div class="group rounded-2xl border border-gray-100 bg-white p-7 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-gold/40 hover:shadow-lg">
            <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-navy text-gold transition-colors group-hover:bg-gold group-hover:text-navy-dark">
              <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={icons[s.icon] ?? icons.stethoscope} />
              </svg>
            </div>
            <h3 class="mb-2 font-serif text-xl font-700 text-navy">{s.title}</h3>
            <p class="text-sm leading-relaxed text-gray-600">{s.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

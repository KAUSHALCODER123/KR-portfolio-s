---
import { config } from '../config.js';
import SectionHeading from './SectionHeading.astro';

const { contact, clinic } = config;
const waLink = `https://wa.me/${contact.whatsapp}?text=${encodeURIComponent(
  contact.whatsappMessage,
)}`;
---

<section id="contact" class="bg-cream py-20">
  <div class="mx-auto max-w-4xl px-5">
    <SectionHeading eyebrow="Get In Touch" title="Book Your Visit" />

    <div class="overflow-hidden rounded-3xl bg-white shadow-lg md:grid md:grid-cols-5">
      <!-- Highlighted CTA panel -->
      <div class="flex flex-col justify-center bg-navy p-8 md:col-span-2">
        <h3 class="font-serif text-2xl font-700 text-white">
          Ready when you are.
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-white/70">
          Tap below to message us on WhatsApp — we’ll confirm your appointment slot
          right away.
        </p>
        <a
          href={waLink}
          target="_blank"
          rel="noopener"
          class="mt-6 inline-flex items-center justify-center gap-2 rounded-full bg-gold px-6 py-3.5 text-base font-600 text-navy-dark shadow-md transition-all hover:bg-gold-dark hover:shadow-lg"
        >
          <svg class="h-5 w-5 shrink-0" viewBox="-2 -2 28 28" fill="currentColor" aria-hidden="true">
            <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.519 5.26l-.999 3.648 3.736-.979.234.002zm5.413-6.246c-.075-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z" />
          </svg>
          Chat on WhatsApp
        </a>
      </div>

      <!-- Details -->
      <div class="space-y-5 p-8 md:col-span-3">
        <a
          href={`tel:${contact.phoneDisplay.replace(/\s/g, '')}`}
          class="flex items-start gap-4 rounded-xl p-3 transition-colors hover:bg-cream"
        >
          <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-gold-soft text-gold-dark">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.7a2 2 0 0 1-.5 2.1L8 9.8a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.4c.9.3 1.8.5 2.7.6a2 2 0 0 1 1.7 2z" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <span>
            <span class="block text-xs font-600 uppercase tracking-wide text-gray-400">Phone</span>
            <span class="text-base font-600 text-navy">{contact.phoneDisplay}</span>
          </span>
        </a>

        <a
          href={`mailto:${contact.email}`}
          class="flex items-start gap-4 rounded-xl p-3 transition-colors hover:bg-cream"
        >
          <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-gold-soft text-gold-dark">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="3" y="5" width="18" height="14" rx="2" />
              <path d="m3 7 9 6 9-6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <span>
            <span class="block text-xs font-600 uppercase tracking-wide text-gray-400">Email</span>
            <span class="text-base font-600 text-navy">{contact.email}</span>
          </span>
        </a>

        <div class="flex items-start gap-4 p-3">
          <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-gold-soft text-gold-dark">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M12 21s-7-6-7-11a7 7 0 0 1 14 0c0 5-7 11-7 11z" stroke-linejoin="round" />
              <circle cx="12" cy="10" r="2.5" />
            </svg>
          </span>
          <span>
            <span class="block text-xs font-600 uppercase tracking-wide text-gray-400">Clinic Address</span>
            <address class="not-italic text-sm leading-relaxed text-gray-600">
              {clinic.addressLines.map((line) => <span class="block">{line}</span>)}
            </address>
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

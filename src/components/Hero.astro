---
import { config } from '../config.js';

const { doctor } = config;
const waLink = `https://wa.me/${config.contact.whatsapp}?text=${encodeURIComponent(
  config.contact.whatsappMessage,
)}`;
const initials = doctor.name
  .replace(/^Dr\.?\s*/i, '')
  .split(' ')
  .map((w) => w[0])
  .slice(0, 2)
  .join('');
---

<section
  id="top"
  class="relative overflow-hidden bg-gradient-to-b from-cream to-white pt-28 pb-16 md:pt-36 md:pb-24"
>
  <!-- Decorative soft shapes -->
  <div
    class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-gold-soft/60 blur-3xl"
  >
  </div>
  <div
    class="pointer-events-none absolute -left-20 bottom-0 h-64 w-64 rounded-full bg-navy/5 blur-3xl"
  >
  </div>

  <div
    class="relative mx-auto grid max-w-6xl items-center gap-10 px-5 md:grid-cols-2 md:gap-12"
  >
    <!-- Text -->
    <div class="reveal text-center md:text-left">
      <span
        class="inline-flex items-center gap-2 rounded-full border border-gold/40 bg-gold-soft/60 px-4 py-1.5 text-sm font-600 text-navy"
      >
        <span class="h-2 w-2 rounded-full bg-gold"></span>
        {doctor.specialization}
      </span>

      <h1
        class="mt-5 font-serif text-4xl font-700 leading-tight text-navy sm:text-5xl"
      >
        {doctor.name}
      </h1>
      <p class="mt-2 text-lg font-500 text-gold-dark">{doctor.qualifications}</p>

      <p class="mt-5 max-w-md text-base leading-relaxed text-gray-600 md:mx-0 mx-auto">
        Caring for you and your family with {doctor.yearsExperience}+ years of trusted,
        evidence-based medical practice.
      </p>

      <div
        class="mt-8 flex flex-col items-center gap-3 sm:flex-row md:justify-start justify-center"
      >
        <a
          href={waLink}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-full bg-gold px-7 py-3.5 text-base font-600 text-navy-dark shadow-md transition-all hover:bg-gold-dark hover:shadow-lg"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.519 5.26l-.999 3.648 3.736-.979 .234 .002zm5.413-6.246c-.075-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"
            />
          </svg>
          Book Appointment
        </a>
        <a
          href="#services"
          class="inline-flex items-center gap-2 rounded-full border border-navy/15 px-7 py-3.5 text-base font-600 text-navy transition-colors hover:bg-navy/5"
        >
          View Services
        </a>
      </div>
    </div>

    <!-- Photo / placeholder -->
    <div class="reveal flex justify-center md:justify-end" style="animation-delay:.1s">
      <div class="relative">
        <div
          class="absolute -inset-3 rounded-[2rem] bg-gradient-to-br from-gold/30 to-navy/10"
        >
        </div>
        {doctor.photo && (
          <img
            src={doctor.photo}
            alt={doctor.name}
            onerror="this.onerror=null;this.style.display='none';this.nextElementSibling.style.display='flex';"
            class="relative h-72 w-72 rounded-[1.75rem] object-cover shadow-xl sm:h-80 sm:w-80"
          />
        )}
        <!-- Fallback shown when no photo is set, or the image fails to load. -->
        <div
          class="relative h-72 w-72 flex-col items-center justify-center rounded-[1.75rem] bg-navy shadow-xl sm:h-80 sm:w-80"
          style={doctor.photo ? 'display:none' : 'display:flex'}
        >
          <span class="font-serif text-6xl font-700 text-gold">{initials}</span>
          <span class="mt-3 text-sm font-500 text-white/70">Photo placeholder</span>
        </div>
        <!-- Experience badge -->
        <div
          class="absolute -bottom-4 -left-4 rounded-2xl bg-white px-5 py-3 text-center shadow-lg"
        >
          <div class="font-serif text-2xl font-700 text-navy">
            {doctor.yearsExperience}+
          </div>
          <div class="text-xs font-500 uppercase tracking-wide text-gray-500">
            Years Exp.
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
